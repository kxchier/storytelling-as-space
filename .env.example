# ---- Frontend (Vercel) ----
# URL of the deployed backend. Leave unset locally to default to http://localhost:3001
VITE_API_URL=http://localhost:3001

# ---- Backend (Render / Railway / Fly) ----
# Replicate API token for image generation
REPLICATE_API_TOKEN=your_replicate_token_here

# Optional: comma-separated list of allowed frontend origins for CORS.
# e.g. https://your-app.vercel.app  (omit to allow all origins)
CORS_ORIGIN=
